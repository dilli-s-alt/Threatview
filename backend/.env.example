PORT=3001
NODE_ENV=development

# API Keys (Get yours from respective providers)
ALIENVAULT_API_KEY=your_otx_key_here
SHODAN_API_KEY=your_shodan_key_here
PHISHTANK_API_KEY=your_phishtank_key_here

# Email Service (SendGrid)
SENDGRID_API_KEY=your_sendgrid_key_here
SENDGRID_FROM_EMAIL=your_verified_sender@example.com

# Database & Logging
DB_FILE_PATH=./db.json
LOG_LEVEL=info
VERBOSE_LOGS=false

# Feature Flags
ENABLE_EMAIL_ALERTS=true
ENABLE_SCHEDULED_INGESTION=true
INGESTION_INTERVAL_MINUTES=60

# Mock Modes (Set to true to develop without real APIs)
MOCK_EMAIL=true
MOCK_SOURCES=true